@model IEnumerable<house_crud.Models.house>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.owner_name)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.house_address)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.nearest_place)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.owner_name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.house_address)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.nearest_place)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.house_number }) |
            @Html.ActionLink("Details", "Details", new { id=item.house_number }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.house_number })
        </td>
    </tr>
}

</table>
